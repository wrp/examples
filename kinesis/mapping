  │ End              │ 0x4d │ 0x70000004d │
  ├──────────────────┼──────┼─────────────┤
  │ Page Up          │ 0x4b │ 0x70000004b │
  ├──────────────────┼──────┼─────────────┤
  │ Page Down        │ 0x4e │ 0x70000004e │
  ├──────────────────┼──────┼─────────────┤
  │ Insert           │ 0x49 │ 0x700000049 │
  ├──────────────────┼──────┼─────────────┤
  │ Delete (fwd)     │ 0x4c │ 0x70000004c │
  ├──────────────────┼──────┼─────────────┤
  │ Left Ctrl        │ 0xe0 │ 0x7000000e0 │
  ├──────────────────┼──────┼─────────────┤
  │ Left Shift       │ 0xe1 │ 0x7000000e1 │
  ├──────────────────┼──────┼─────────────┤
