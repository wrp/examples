  ├──────────────────┼──────┼─────────────┤
  │ Right Ctrl       │ 0xe4 │ 0x7000000e4 │
  ├──────────────────┼──────┼─────────────┤
  │ Right Shift      │ 0xe5 │ 0x7000000e5 │
