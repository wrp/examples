{
  "comment": "Put this in $HOME/.claude/settings.json",
  "model": "claude-opus-4-6",
  "statusLine": {
    "type": "command",
    "command": "/Users/wrp/.claude/statusline"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '\"#\" + (now | floor | tostring) + \" (\" + (now | strftime(\"%Y-%m-%dT%H:%M:%S%Z\")) + \" \" + .session_id[:8] + \":\" + .cwd + \")\\n\" + .tool_input.command' >> ~/.claude/bash_history.log"
          }
        ]
      }
    ]
  }
}
