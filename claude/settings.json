{
  "comment": "Put this in $HOME/.claude/settings.json",
  "model": "claude-opus-4-6",
  "statusLine": {
    "type": "command",
    "command": "/Users/wrp/.claude/statusline"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '\"#\" + (now | floor | tostring) + \"\\t\" + .session_id + \"\\t\" + .cwd, .tool_input.command' >> ~/.claude/bash_history.log"
          }
        ]
      }
    ]
  }
}
