{
  "comment": "Put this in $HOME/.claude/settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '\"#\" + (now | floor | tostring), .tool_input.command' >> ~/.claude/bash_history.log"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline"
  }
}
