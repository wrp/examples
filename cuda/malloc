
*Never* use malloc in C++.  CUDA is C++.  If you want memory for data
that will be sent to the device, use cudaMallocHost.  If you want
memory for something else, use std::vector or std::make_unique (or
maybe new/delete, but that's obsolete)

eg: (from https://docs.nvidia.com/cuda/cuda-programming-guide/02-basics/intro-to-cuda-cpp.html)

//Allocate Host Memory
cudaMallocHost(&A, size * sizeof *A);
cudaMallocHost(&B, size * sizeof *B);
cudaMallocHost(&C, size * sizeof *C);

initArray(A, size);
initArray(B, size);

// Allocate memory on the GPU
cudaMalloc(&devA, size * sizeof *devA);
cudaMalloc(&devB, size * sizeof *devB);
cudaMalloc(&devC, size * sizeof *devC);

// Copy data to the GPU
cudaMemcpy(devA, A, size * sizeof *A, cudaMemcpyDefault);
cudaMemcpy(devB, B, size * sizeof *B, cudaMemcpyDefault);
cudaMemset(devC, 0, size * sizeof *C);

cudaFree(devA);
cudaFree(devB);
cudaFree(devC);
cudaFreeHost(A);
cudaFreeHost(B);
cudaFreeHost(C);


// Setting heap size on the device (https://docs.nvidia.com/cuda/cuda-programming-guide/05-appendices/cpp-language-support.html#cuda-c-standard-library)
cudaDeviceGetLimit(size_t* size, cudaLimitMallocHeapSize)
cudaDeviceSetLimit(cudaLimitMallocHeapSize, size_t size)
The heap size granted will be at least size bytes. cuCtxGetLimit() and cudaDeviceGetLimit() return the currently requested heap size.
