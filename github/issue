
gh search issues --assignee @me     # Show assigned issues in all repositories

gh issue --help
gh issue ${cmd?} --help

gh issue view $N                       # view issue N
gh issue view $N --repo $OWNER/$REPO   # view issue N
gh api /repos/$OWNER/$REPO/issues/$N   # view issue N

gh issue list --assignee @me   #  See all assigned open issues
gh issue list --assignee @me --state  {open|closed|all} (default "open")
gh issue list --state open --json title,assignees

# Show title and assignee of open issues:
tabs 20,+8; gh issue list --state open --json title,assignees | jq -r '.[] |
	[([.assignees[].login] | join(",")), .title] | @tsv'

# Sigh.  Claude recommends --no-assignee, but option unavailable in 'version 2.83.1 (2025-11-13)'
gh issue list --search "is:open no:assignee"
gh issue list --no-assignee                     #  See all unassigned issues
gh issue list --no-assignee --search "is:open"  #  See all unassigned, open issues
gh issue list --no-assignee --label bug

gh issue list --assignee @me --state open --search is:open   # List issues in all accessible repos
gh issue list --assignee @me --repo owner/repo               # Limit to specific repository

gh issue list --assignee @me --limit 100         # Show more issues (default is 30)
gh issue list --assignee @me --json number,title,url,labels   # Include additional fields in output

gh issue list --assignee @me --label bug         # Filter issues by label


# Assign all issues in a milestone (untested)
for issue_number in $(gh issue list --milestone "$milestone" \
	--state open --json number | jq -r '.[].number')
do
	gh issue assign "$issue_number" @me
done


--json accepts the following fields:
	assignees, author, body, closed, closedAt, closedByPullRequestsReferences, comments,
	createdAt, id, isPinned, labels, milestone, number, projectCards, projectItems,
	reactionGroups, state, stateReason, title, updatedAt, url,


** Creating issues
gh issue create --title "I found a bug" --body "Nothing works"


create flags:  (from 'gh issue create --help)
  -a, --assignee login   Assign people by their login. Use "@me" to self-assign.
  -b, --body string      Supply a body. Will prompt for one otherwise.
  -F, --body-file file   Read body text from file (use "-" to read from standard input)
  -e, --editor           Skip prompts and open the text editor to write the title and body in. The first line is the title and the remaining text is the body.
  -l, --label name       Add labels by name
  -m, --milestone name   Add the issue to a milestone by name
  -p, --project title    Add the issue to projects by title
      --recover string   Recover input from a failed run of create
  -T, --template name    Template name to use as starting body text
  -t, --title string     Supply a title. Will prompt for one otherwise.
  -w, --web              Open the browser to create an issue
