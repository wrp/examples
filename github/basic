# Find all my pull-requests:
gh pr list --author @me

# Show details of a pr:
gh pr view $N
gh pr view $N --comments     # include comments
gh api repos/${owner}/${repo}/pulls/$N/comments # For review comments
gh api repos/${owner}/${repo}/issues/$N/comments # For issue-style (top-level) comments



gh api repos/$owner/$repo/milestones           # Get open milestones
gh api repos/$owner/$repo/milestones?state=all # Get all milestones


gh api --paginate ...   # For pagination


gh issue view $N                       # view issue N
gh issue view $N --repo $OWNER/$REPO   # view issue N
gh api /repos/$OWNER/$REPO/issues/$N   # view issue N


gh run watch $id  # Get periodic status update on a job
