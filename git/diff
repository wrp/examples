# By default, git-diff shows the difference between the working tree and the index.

git diff                            # Show diff to get from the index to the worktree
git diff ${treeish}                 # Show diff to get from treeish to the working tree
git diff ${treeish1} ${treeish2}    # Show diff to get from $treeish1 to $treeish2
git diff ${treeish1}..${treeish2}   # Same as git diff ${treeish1} ${treeish2}

# Show the diff from branch-point to commit
git diff --name-only $(git merge-base ${main} ${commit})..${commit}
git diff --merge-base ${main} ${commit}  # equivalent
git diff ${main}...${commit}             # equivalent


git diff --name-only --diff-filter=A  # Show only added files
git diff --name-only --diff-filter=a  # Exclude added files


# Ignore files in which the only change is addition or removal of empty lines.
# This will show changed lines with only whitespace, but . does not match
# newline, so purely empty lines will not be detected and the file
# will be omitted from consideration.
git diff -G.
