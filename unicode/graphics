#!/usr/bin/env perl
# A random collection of symbols.
# printf '\xf0\x9f\x9b\x91 \U1f6d1'  # Shell printf

# Mapping from a code-point to a byte sequence is a bit
# convoluted.  The point code \U1f6d1 uses the template
# 11110xxx  10xxxxxx  10xxxxxx  10xxxxxx

# 1f6d1 == 0 0001 1111 0110 1101 0001, so we fill in the
# template to get:
# 11110xxx  10xxxxxx  10xxxxxx  10xxxxxx
#      ^^^    ^^^^^^    ^^^^^^    ^^^^^^
#      000    011111    011011    010001
# 11110000  10011111  10011011  10010001
# 0xf0      9f         9b        91
#


# ❯ What unicode code-point can generate the sequence '\xe2\x9c\x8b'?
# That's U+270B, the "raised hand" emoji (✋).
#  The UTF-8 encoding breaks down as:
#
#  - 0xe2 = 1110 0010 → first byte of a 3-byte sequence, upper nibble 0010
#  - 0x9c = 10 011100 → continuation, payload 011100
#  - 0x8b = 10 001011 → continuation, payload 001011
#  Combined payload: 0010 011100 001011 = 0x270B.


use 5.12.0;
use Unicode::UCD "charinfo";
use Data::Dumper;

my $misc = "✓✗";

my @samples = (
	'e29c93',    # check ✓
	'f09f9b91',  # A stop sign: 🛑  \U1f6d1
	'e29c8b',    # A yellow hand  ✋  \U270B
	'f09f8c80',  # Debian symbol 🌀
	'f09f8cb9',  # A rose 🌹
	'f09f92ac',  # Text bubble 💬  \U1F4AC
	'e2888a',    # ∊   epsilon
	'e28888',    # ∈   epsilon element
	'e280a6',    # …   ellipsis
	'e2889e',    # ∞   infinity
	'e28b85',    # ⋅   multiplication symbol, multiply
	'c2b1',      # ±   plus/minus
	'c2b2',      #     superscript 2
	'c2b3',      #     superscript 3
	'c3b7',      # ÷   division, obelus
	'cebc',      # μ
	'cf80',      # π   pi
	'e284af',    # ℯ   e the base of natural log
	'e28a86',    # ⊆   Subset
	'e284a4',    # ℤ   integers
	'e29ca8',    # ✨  stars
	'e29c85',    # ✅  check
	'e2ac86',    # ⬆    up arrow

);
printf "%s", pack "H*", $_ foreach @samples; print "\n";
# print Dumper(charinfo(0x1f6d1));

sub print_range {
	printf("%x .. %x: ", $_[0], $_[1]);
	foreach my $x ($_[0]..$_[1]) {
		my $s = sprintf('%x', $x);
		printf "%s", pack "H*", $s;
	}
	print "\n";
}

sub print_32 { print_range $_[0], $_[0] + 31; }
