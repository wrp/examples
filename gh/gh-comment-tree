#!/usr/bin/env python3
"""Display GitHub PR comments in tree format.

Usage:
	gh-comment-tree ${pr}	# pr should be an integer
	gh-comment-tree owner/repo ${pr}
	gh api repos/OWNER/REPO/pulls/N/comments | gh-comment-tree
"""

import json
import subprocess
import sys
import textwrap
from collections import defaultdict

def get_repo():
	result = subprocess.run(
		[
			"gh", "repo", "view", "--json", "nameWithOwner",
			"--jq", ".nameWithOwner"
		],
		capture_output=True, text=True,
	)
	if result.returncode != 0:
		sys.exit("Unable to get remote for cwd:" + result.stderr.strip())
	return result.stdout.strip()


def fetch_comments(arg, repo):
	path = f"repos/{repo}/pulls/{arg}/comments"
	result = subprocess.run(
		["gh", "api", "--paginate", path],
		capture_output=True, text=True,
	)
	if result.returncode != 0:
		sys.exit(f'Failed to pull results from {path}:' + result.stderr.strip())

	return json.loads(result.stdout)


def main():
	if len(sys.argv) == 2:
		repo = get_repo()
		pr = int(sys.argv[1])
	elif len(sys.argv) == 3:
		repo = sys.argv[1]
		pr = int(sys.argv[2])
	elif len(sys.argv) > 3:
		raise SystemExit('Unexpected arguments')

	if len(sys.argv) > 1:
		comments = fetch_comments(pr, repo)
	else:
		comments = json.load(sys.stdin)

	by_id = {}
	children = defaultdict(list)
	roots = []

	for c in comments:
		by_id[c["id"]] = c
		parent = c.get("in_reply_to_id")
		if parent:
			children[parent].append(c["id"])
		else:
			roots.append(c["id"])

	for i, rid in enumerate(roots):
		if i > 0:
			print()
		print_root(by_id, children, rid)


def format_body(body, prefix):
	lines = []
	for bline in body.splitlines():
		if not bline.strip():
			lines.append(prefix)
			continue
		wrapped = textwrap.fill(
			bline,
			width=76,
			initial_indent=prefix,
			subsequent_indent=prefix,
		)
		lines.append(wrapped)
	return "\n".join(lines)


def print_root(by_id, children, cid):
	c = by_id[cid]
	user = c["user"]["login"]
	date = c["created_at"][:19].replace("T", " ")
	path = c.get("path", "")
	line = c.get("original_line", "")
	oid = c.get("original_commit_id", '')[:7]

	header = f"{user} ({date}) {oid} {path}:{line}"

	print(f"{header}")
	body = format_body(c["body"], "    ")
	print(body)

	kids = children.get(cid, [])
	for i, child_id in enumerate(kids):
		print_reply(by_id, children, child_id, i == len(kids) - 1, "    ")


def print_reply(by_id, children, cid, is_last, prefix):
	c = by_id[cid]
	user = c["user"]["login"]
	date = c["created_at"][:19].replace("T", " ")

	connector = "\u2514\u2500\u2500 " if is_last else "\u251c\u2500\u2500 "
	print(f"{prefix}{connector}{user} ({date})")

	continuation = prefix + ("    " if is_last else "\u2502   ")
	body = format_body(c["body"], continuation + "  ")
	print(body)

	kids = children.get(cid, [])
	for i, child_id in enumerate(kids):
		print_reply(by_id, children, child_id, i == len(kids) - 1, continuation)


if __name__ == "__main__":
	main()
